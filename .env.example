# Supabase (local dev, run by `supabase start`)
#
# Auth keys are NOT committed here: newer Supabase CLIs generate per-instance
# signing keys, so the anon/service_role values differ on every machine.
# `make up` reads the live keys from `supabase start` and injects them
# automatically (see scripts/supabase-env.sh) -- you do NOT need to fill these in.
# They only matter if you bypass make and run `docker compose up` directly, in
# which case run `make supabase-status` and paste the real values here.
#
# Two URLs intentionally differ by run context:
#   SUPABASE_URL       -> used by the Temporal worker, which runs INSIDE Docker and
#                         reaches the host-bound Supabase via host.docker.internal.
#   VITE_SUPABASE_URL  -> used by the frontend, which runs in the browser on the HOST.
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=injected-by-make-up
SUPABASE_SERVICE_ROLE_KEY=injected-by-make-up

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=main
HTTP_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# LLM provider for llm_agent activity (via @earendil-works/pi-ai).
# Set PIAGENT_PROVIDER to one of the options below, and fill in only
# the matching API key. All other key vars can be left blank.
#
# Provider options: anthropic | openai | amazon-bedrock | google |
#                   azure-openai-responses | openrouter | groq | mistral
PIAGENT_PROVIDER=anthropic
PIAGENT_MODEL_ID=claude-sonnet-4-6
# Azure sandbox canonical pair for issue #62 smoke runs:
#   PIAGENT_PROVIDER=azure-openai-responses
#   PIAGENT_MODEL_ID=gpt-4o

# Anthropic (provider: anthropic)
ANTHROPIC_API_KEY=
# OpenAI (provider: openai)
OPENAI_API_KEY=
# Azure OpenAI (provider: azure-openai-responses)
# AZURE_OPENAI_BASE_URL is the canonical var read by the worker.
# AZURE_OPENAI_ENDPOINT (the official Azure SDK name) is accepted as an alias.
# AZURE_API_BASE and AZURE_API_KEY are accepted aliases.
#
# Confirmed sandbox deployment (issue #62 evidence):
#   Resource:    https://volarisiaisandboxazureopenai.openai.azure.com
#   Deployment:  gpt-4o   ← the only confirmed active deployment on this resource
#
# gpt-5.4 returns 404 DeploymentNotFound on volarisiaisandboxazureopenai.openai.azure.com.
# That deployment does not exist on this sandbox resource. To use gpt-5.4 you must either:
#   a) provision a gpt-5.4 deployment on this resource in Azure Portal / CLI, or
#   b) point AZURE_OPENAI_BASE_URL at a different Azure resource that has gpt-5.4 deployed.
# Until that is done, set PIAGENT_MODEL_ID=gpt-4o for sandbox smoke runs.
#
# The llm_agent activity now requires an explicit deployment name for azure-openai-responses —
# it no longer silently falls back to gpt-4o. Set PIAGENT_MODEL_ID to the Azure deployment
# name you have verified on the target resource.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_ENDPOINT=
AZURE_API_BASE=https://volarisiaisandboxazureopenai.openai.azure.com
AZURE_API_KEY=
AZURE_API_VERSION=2025-03-01-preview
# AWS Bedrock (provider: amazon-bedrock) — uses IAM, no explicit key needed if role attached
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Google Gemini (provider: google) — uses GOOGLE_API_KEY or Application Default Credentials
GOOGLE_API_KEY=
# OpenRouter (provider: openrouter)
OPENROUTER_API_KEY=
# Groq (provider: groq)
GROQ_API_KEY=
# Mistral (provider: mistral)
MISTRAL_API_KEY=

# Exa Search — used by web_search and web_crawl activities (also the crawl_site
# built-in tool in llm_agent).  Both activities return empty results gracefully
# when this is unset; set it for real web search and site-crawl in the smoke test.
# Get your key at: https://dashboard.exa.ai
# Set as a GitHub secret for CI:  gh secret set EXA_API_KEY --repo <org>/<repo>
EXA_API_KEY=

# Frontend (browser on the host -> localhost)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=injected-by-make-up
VITE_API_URL=http://localhost:54321/functions/v1
VITE_WORKFLOW_API_URL=http://localhost:3001
