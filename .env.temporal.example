# Temporal namespace/task-queue defaults for local Docker runs.
#
# These defaults intentionally mirror the dev Kubernetes profile so local
# workflow triggering matches staging behavior.
TEMPORAL_NAMESPACE=10x-stack-dev
TEMPORAL_TASK_QUEUE=10x-stack-dev-main
#
# Optional local override:
#   Copy this file to .env.temporal and switch values to classic local naming.
#   See README.md for the exact override values.
