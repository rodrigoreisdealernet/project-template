{
  "name": "temporal-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "biome check --write .",
    "start": "node dist/worker.js",
    "dev": "ts-node src/worker.ts",
    "test": "jest --forceExit",
    "licenses": "license-checker --summary",
    "licenses:check": "license-checker --summary --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;Unlicense;CC0-1.0;Python-2.0;BlueOak-1.0.0;MIT OR Apache-2.0;MIT-0;MPL-2.0;CC-BY-4.0;CC-BY-3.0;(MIT AND CC-BY-3.0);(MIT OR CC0-1.0);Apache-2.0 AND MIT;MIT*;BSD*;Public Domain;Custom: http://github.com/substack/node-bufferlist;(MIT OR GPL-3.0-or-later);(MIT AND Zlib)' --excludePrivatePackages"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.10",
    "@hono/node-server": "^2.0.5",
    "@temporalio/activity": "^1.18.1",
    "@temporalio/client": "^1.18.1",
    "@temporalio/worker": "^1.18.1",
    "@temporalio/workflow": "^1.18.1",
    "cheerio": "^1.2.0",
    "exceljs": "^4.4.0",
    "hono": "^4.12.27",
    "mammoth": "^1.11.0",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@temporalio/testing": "^1.18.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.0",
    "jest": "^30.4.2",
    "license-checker": "^25.0.1",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@temporalio/proto": {
      "protobufjs": "7.6.4"
    },
    "uuid": "^11.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 45,
        "functions": 40,
        "branches": 38,
        "statements": 45
      }
    },
    "testTimeout": 30000,
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  }
}
