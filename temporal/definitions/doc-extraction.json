{
  "name": "doc-extraction",
  "version": "1.0.0",
  "description": "Fetch a document, extract structured fields with an LLM, and store the extraction result.",
  "input_schema": {
    "type": "object",
    "required": ["source_url", "run_at"],
    "properties": {
      "source_url": { "type": "string", "minLength": 1 },
      "run_at": { "type": "string", "minLength": 1 },
      "alert_user_id": { "type": "string" },
      "workflow_id": { "type": "string" }
    },
    "additionalProperties": false
  },
  "steps": {
    "sequence": {
      "steps": [
        {
          "activity": {
            "name": "http_request",
            "args": {
              "method": "GET",
              "url": "$input.source_url",
              "expected_status": [200]
            },
            "result": "document_response",
            "start_to_close_timeout": "60s",
            "retry": { "max_attempts": 3, "initial_interval": "2s" },
            "output_schema": {
              "oneOf": [
                { "type": "string" },
                { "type": "object" },
                { "type": "array" }
              ]
            }
          }
        },
        {
          "activity": {
            "name": "transform_data",
            "args": {
              "input": {
                "source_url": "$input.source_url",
                "document_text": "$var.document_response"
              },
              "mapping": {
                "source_url": "source_url",
                "document_text": "document_text"
              }
            },
            "result": "normalized_document",
            "start_to_close_timeout": "15s",
            "output_schema": {
              "type": "object",
              "required": ["source_url", "document_text"],
              "properties": {
                "source_url": { "type": "string" },
                "document_text": {
                  "type": ["string", "object", "array"]
                }
              }
            }
          }
        },
        {
          "activity": {
            "name": "llm_agent",
            "args": {
              "system_prompt": "You extract bibliographic fields from technical documents. Return only valid JSON conforming to the schema.",
              "user_prompt": "Extract fields from this document.\\n\\nSource URL: $var.normalized_document.source_url\\n\\nDocument content:\\n$var.normalized_document.document_text",
              "provider": "anthropic",
              "model_id": "claude-sonnet-4-6",
              "response_schema": {
                "type": "object",
                "required": ["title", "authors", "abstract", "year", "confidence"],
                "properties": {
                  "title": { "type": "string", "minLength": 1 },
                  "authors": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                  },
                  "abstract": { "type": "string", "minLength": 1 },
                  "year": { "type": "number" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
                },
                "additionalProperties": false
              },
              "schema_name": "document_extraction",
              "temperature": 0,
              "max_tokens": 1000
            },
            "result": "extraction_response",
            "start_to_close_timeout": "120s",
            "retry": { "max_attempts": 2 },
            "output_schema": {
              "type": "object",
              "required": ["parsed"],
              "properties": {
                "parsed": {
                  "type": "object",
                  "required": ["title", "authors", "abstract", "year", "confidence"],
                  "properties": {
                    "title": { "type": "string" },
                    "authors": { "type": "array" },
                    "abstract": { "type": "string" },
                    "year": { "type": "number" },
                    "confidence": { "type": "number" }
                  }
                },
                "content_filter_blocked": { "type": "boolean" }
              }
            }
          }
        },
        {
          "condition": {
            "if": "$var.extraction_response.parsed.confidence > 0.7",
            "then": {
              "activity": {
                "name": "supabase_mutate",
                "args": {
                  "operation": "upsert",
                  "table": "document_extractions",
                  "match": {
                    "source_url": "$input.source_url"
                  },
                  "values": {
                    "source_url": "$input.source_url",
                    "extracted_fields": {
                      "title": "$var.extraction_response.parsed.title",
                      "authors": "$var.extraction_response.parsed.authors",
                      "abstract": "$var.extraction_response.parsed.abstract",
                      "year": "$var.extraction_response.parsed.year",
                      "confidence": "$var.extraction_response.parsed.confidence"
                    },
                    "confidence": "$var.extraction_response.parsed.confidence",
                    "extracted_at": "$input.run_at"
                  }
                },
                "result": "persist_result",
                "start_to_close_timeout": "30s",
                "retry": { "max_attempts": 3 }
              }
            },
            "else": {
              "activity": {
                "name": "send_notification",
                "args": {
                  "user_id": "$input.alert_user_id",
                  "channel": "in-app",
                  "message": "Document extraction confidence below threshold for $input.source_url",
                  "data": {
                    "source_url": "$input.source_url",
                    "confidence": "$var.extraction_response.parsed.confidence"
                  }
                },
                "result": "confidence_alert_sent",
                "start_to_close_timeout": "15s"
              }
            }
          }
        }
      ]
    }
  }
}
